# PostgreSQL connection string
# Local dev: postgresql://postgres:postgres@localhost:5432/docsignal
# Production: your Neon connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/docsignal

# Groq API key — required for Q&A synthesis (free at console.groq.com)
GROQ_API_KEY=gsk_...

# Embedding provider: fastembed (default, free, local) or openai
EMBEDDING_PROVIDER=fastembed
